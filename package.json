{
  "name": "daybook",
  "version": "0.1.0",
  "description": "Daybook — multi-client daily sales & incident reporting PWA (SaaS). Tenants = client companies; Google sign-in; per-tenant roles. Mirrors otuburu deployment conventions.",
  "main": "backend/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "NODE_ENV=development node backend/server.js",
    "dev:ui": "vite frontend/src --outDir ../dist",
    "build": "vite build",
    "seed": "node backend/seed.js",
    "smoke": "node backend/smoke.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "express": "^4.21.0",
    "google-auth-library": "^9.14.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.9.0",
    "multer": "^2.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.0",
    "qrcode-generator": "^1.4.4",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=20"
  }
}
