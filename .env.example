# ── Daybook environment ────────────────────────────────────────────────────
# Copy to .env on the server (CI writes this fresh on each deploy for otuburu;
# for daybook you can keep a long-lived .env in /opt/daybook/backend/.env).

# App
PORT=8090
NODE_ENV=production
PUBLIC_URL=https://daybook.torama.money

# Auth — REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Google Sign-In (everyone logs in with Google; no passwords) ────────────────
# Reuse otuburu's OAuth client. Add https://daybook.torama.money to that client's
# "Authorized JavaScript origins" in Google Cloud Console → Credentials.
GOOGLE_CLIENT_ID=763064592541-afo8b3po66bmo04q9ecselk9prske4l0.apps.googleusercontent.com

# Platform superadmins (comma separated) — see & manage every company workspace.
SUPERADMIN_EMAILS=filatei@gmail.com,filatei@torama.money

# SQLite database + uploaded files (volume-mounted in Docker)
DAYBOOK_DB_PATH=/data/daybook.db
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=25

# ── Email (Google Workspace SMTP relay — identical to otuburu) ─────────────────
# IP-based auth: the server IP must be whitelisted in
#   Google Admin → Apps → Gmail → Routing → SMTP relay
# When whitelisted, leave SMTP_USER/SMTP_PASS blank (no password needed).
# To use an App Password instead, set both SMTP_USER and SMTP_PASS.
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Daybook <noreply@torama.money>

# Default daily-report recipients (comma separated). Admins can override per
# tenant in the app. Mirrors the sample report distribution list.
DEFAULT_REPORT_RECIPIENTS=dailyreports@gtsng.com

# ── AI assistant (same keys as the etax app — one Anthropic key serves both) ──
# Leave AI_API_KEY blank to disable AI features gracefully.
AI_API_KEY=
AI_API_URL=https://api.anthropic.com/v1/messages
AI_MODEL=claude-haiku-4-5-20251001
# Optional local LLM fallback on rate-limit/overload:
# AI_FALLBACK_URL=http://localhost:11434/v1/chat/completions
# AI_FALLBACK_MODEL=qwen2.5:7b

# ── Sales source (fido POS Mongo via SSH tunnel) — fill to enable ─────────────
FIDO_SSH_HOST=fido.torama.ng
FIDO_SSH_PORT=2525
FIDO_SSH_USER=
# Host is host.docker.internal (the app runs in a container; the tunnel listens on
# the host at :27018). Not 127.0.0.1 — that's the container's own loopback.
SALES_MONGO_URL=
SALES_DB=fido_db
SALES_TZ_OFFSET=+01:00

# ── Nightly POS → Daybook sync (snapshots each site's sales into reports) ─────
SYNC_ENABLED=0
SYNC_CRON=30 22 * * *
SYNC_TZ=Africa/Lagos
SYNC_EMAIL=0

# ── Cutover data flow (parallel-testing phase) ────────────────────────────────
# Requires SALES_MONGO_URL set + the fido SSH tunnel up.
# 1) Live-persist: every new fido sale is upserted into pos_sales in real time
#    (idempotent). On by default when the sales source is configured.
LIVE_PERSIST=1
#    First-tick look-back (minutes) so a restart never misses recent sales.
LIVEFEED_LOOKBACK_MIN=180
# 2) Scheduled ETL: keeps ALL fido data current (expenses, customers, vendors,
#    staff, generators, products) — not just live sales. Runs nightly as a delta
#    (orders/expenses since today-ETL_BACKFILL_DAYS; reference sets refresh fully).
ETL_ENABLED=1
ETL_CRON=0 1 * * *
ETL_BACKFILL_DAYS=2

# ── Payments — same providers/keys/var-names as VOTE & Otuburu ────────────────
# Monnify is the primary NGN rail; Paystack is the automatic fallback when
# Monnify isn't configured. Leave both blank to disable self-serve checkout
# (the Subscription screen then just says "contact Torama"). Test keys work
# end-to-end against each provider's sandbox.
PAYMENT_PROVIDER=monnify          # 'monnify' (primary) or 'paystack'
PAYMENT_CURRENCY=NGN
# Monthly price per plan, in naira (whole units). Adjust to taste.
PRICE_STANDARD=15000
PRICE_PRO=40000
# Public site root — used to build gateway return URLs (?pay=ref / ?sub=success)
# and where the dashboard lands after payment.
PUBLIC_BASE_URL=https://daybook.torama.money
# Optional: override the gateway return base (defaults to PUBLIC_BASE_URL).
PAYMENT_CALLBACK_URL=

# Monnify (primary). Webhook → https://daybook.torama.money/api/billing/webhook/monnify
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WALLET_ACCOUNT=
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Paystack (fallback). Webhook → https://daybook.torama.money/api/billing/webhook/paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=

# Lemon Squeezy — optional auto-renewing subscription rail (USD).
# Webhook → https://daybook.torama.money/api/billing/webhook/lemonsqueezy (HMAC-SHA256)
SUBSCRIPTIONS_ENABLED=0
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
SUBSCRIPTION_PRICE_LABEL=$8 / month

# Dev/testing only — enables /api/auth/dev-login (password-less) when NODE_ENV
# is not 'production'. NEVER set this to 1 in production.
DAYBOOK_ALLOW_DEV_LOGIN=0
