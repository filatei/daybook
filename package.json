{
  "name": "daybook",
  "version": "0.1.0",
  "description": "Daybook — multi-client daily sales & incident reporting PWA (SaaS). Tenants = client companies; Google sign-in; per-tenant roles. Mirrors otuburu deployment conventions.",
  "main": "backend/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "NODE_ENV=development node backend/server.js",
    "dev:ui": "vite frontend/src --outDir ../dist",
    "build": "vite build",
    "seed": "node backend/seed.js",
    "smoke": "node backend/smoke.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "express": "^4.21.0",
    "google-auth-library": "^9.14.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.9.0",
    "multer": "^2.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.0",
    "qrcode-generator": "^1.4.4",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=20"
  }
}
